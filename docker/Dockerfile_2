# Amatsukaze Dockerfile
# Ubuntu 22.04ベースでAmatsukazeを実行するためのマルチステージビルド
# デバッグモードとリリースモードの両方に対応

# ビルド段階
FROM ubuntu:22.04 AS builder

# 変数の定義
ARG UBUNTU_VERSION=22.04
ARG ARCH=amd64
ARG BUILD_MODE=release

# 環境変数の設定
ENV DEBIAN_FRONTEND=noninteractive
ENV TZ=Asia/Tokyo
ENV UBUNTU_VERSION=${UBUNTU_VERSION}
ENV ARCH=${ARCH}
ENV BUILD_MODE=${BUILD_MODE}

# バージョン定義
ENV AVISYNTHCUDAFILTERS_VER=0.7.1
ENV AVISYNTH_VER=3.7.5
ENV YADIFMOD2_VER=0.2.8
ENV TIVTC_VER=v1.0.29
ENV NNEDI3_REV=a93dbaea9f0dfc3f6d496a3fe01466bc22dd3a88
ENV MASKTOOLS_REV=8291927bf6956981a6412d353da8ca39d49c9d3a
ENV MVTOOLS_VER=2.7.46
ENV RGTOOLS_VER=1.2
ENV GPAC_VER=v2.4.0
ENV LSMASH_REV=18a9ed25c7ff79a7f4f4bf850c345c72179b8998
ENV CHAPTER_EXE_REV=32880d45f088e574285a101e6a49b032bb04f6ea
ENV JOIN_LOGO_SCP_VER=Ver4.1.0_Linux
ENV FDK_AAC_REV=d8e6b1a3aa606c450241632b64b703f21ea31ce3
ENV FDKAAC_VER=v1.0.6
ENV TSREADEX_VER=master-240517
ENV PSISIARC_VER=master-230324
ENV B24TOVTT_VER=master-220402

# ビルドツールのインストール
RUN apt-get update && apt-get install -y \
    build-essential \
    git \
    curl \
    wget \
    tzdata \
    p7zip-full \
    nasm \
    cmake \
    meson \
    ninja-build \
    pkg-config \
    autoconf \
    automake \
    libtool \
    openssl \
    zlib1g \
    libz-dev \
    libssl-dev \
    && rm -rf /var/lib/apt/lists/* \
    && apt-get clean \
    && apt-get autoremove -y

# AviSynth+のインストール
RUN wget https://github.com/rigaya/AviSynthCUDAFilters/releases/download/${AVISYNTHCUDAFILTERS_VER}/avisynth_${AVISYNTH_VER}-1_${ARCH}_Ubuntu${UBUNTU_VERSION}.deb -O avisynth.deb \
    && apt-get install -y ./avisynth.deb \
    && rm ./avisynth.deb

# Avisynthプラグインのビルドとインストール
WORKDIR /tmp/plugins

# yadif
RUN git clone --depth=1 --branch ${YADIFMOD2_VER} https://github.com/Asd-g/yadifmod2 \
    && cd yadifmod2 \
    && mkdir build && cd build && cmake .. \
    && make -j$(nproc) \
    && make install

# TIVTC
RUN git clone --depth=1 --branch ${TIVTC_VER} https://github.com/pinterf/TIVTC \
    && cd TIVTC/src \
    && cmake -DCMAKE_EXPORT_COMPILE_COMMANDS=1 -B build -S . \
    && cmake --build build -j $(nproc) \
    && cd build \
    && make install

# nnedi3
RUN git clone -b avsp --single-branch https://github.com/rigaya/NNEDI3.git \
    && cd NNEDI3 \
    && git checkout ${NNEDI3_REV} \
    && mkdir build && cd build && meson setup .. \
    && ninja \
    && ninja install

# masktools
RUN git clone https://github.com/pinterf/masktools.git \
    && cd masktools \
    && git checkout ${MASKTOOLS_REV} \
    && mkdir build && cd build && cmake .. \
    && make -j$(nproc) \
    && make install

# mvtools
RUN git clone --depth=1 --branch ${MVTOOLS_VER} https://github.com/pinterf/mvtools.git \
    && cd mvtools \
    && mkdir build && cd build && cmake .. \
    && make -j$(nproc) \
    && make install

# RgTools
RUN git clone --depth=1 --branch ${RGTOOLS_VER} https://github.com/pinterf/RgTools.git \
    && cd RgTools \
    && mkdir build && cd build && cmake .. \
    && make -j$(nproc) \
    && make install

# muxerのインストール（ビルドが必要なもののみ）
# mp4box
RUN git clone --depth=1 --branch ${GPAC_VER} https://github.com/gpac/gpac.git \
    && cd gpac \
    && ./configure --static-bin \
    && make -j$(nproc) \
    && make install

# L-SMASH
RUN git clone https://github.com/l-smash/l-smash.git \
    && cd l-smash \
    && git checkout ${LSMASH_REV} \
    && ./configure \
    && make -j$(nproc) \
    && make install

# CM/ロゴ解析ツール
# chapter_exe
RUN git clone https://github.com/rigaya/chapter_exe \
    && cd chapter_exe \
    && git checkout ${CHAPTER_EXE_REV} \
    && cd src \
    && make -j$(nproc) \
    && install -D -t /usr/local/bin chapter_exe

# join_logo_scp
RUN git clone --depth=1 --branch ${JOIN_LOGO_SCP_VER} https://github.com/tobitti0/join_logo_scp \
    && cd join_logo_scp/src \
    && make -j$(nproc) \
    && install -D -t /usr/local/bin join_logo_scp

# 音声エンコーダ
# fdkaac
RUN git clone https://github.com/mstorsjo/fdk-aac.git \
    && cd fdk-aac \
    && git checkout ${FDK_AAC_REV} \
    && ./autogen.sh \
    && ./configure --disable-shared --prefix=$(pwd)/fdk-aac-libs \
    && make -j$(nproc) \
    && make install \
    && cd .. \
    && git clone --depth=1 --branch ${FDKAAC_VER} https://github.com/nu774/fdkaac.git \
    && cd fdkaac \
    && autoreconf -i \
    && PKG_CONFIG_PATH=../fdk-aac/fdk-aac-libs/lib/pkgconfig ./configure \
    && make -j$(nproc) \
    && make install

# tsreadex
RUN git clone --depth=1 --branch ${TSREADEX_VER} https://github.com/xtne6f/tsreadex.git \
    && cd tsreadex \
    && make -j$(nproc) \
    && install -D -t /usr/local/bin tsreadex

# psisiarc
RUN git clone --depth=1 --branch ${PSISIARC_VER} https://github.com/xtne6f/psisiarc.git \
    && cd psisiarc \
    && make -j$(nproc) \
    && install -D -t /usr/local/bin psisiarc

# b24tovtt
RUN git clone --depth=1 --branch ${B24TOVTT_VER} https://github.com/xtne6f/b24tovtt.git \
    && cd b24tovtt \
    && make -j$(nproc) \
    && install -D -t /usr/local/bin b24tovtt

# ビルド段階のクリーンアップ
RUN rm -rf /tmp/plugins \
    && rm -rf /var/cache/apt/* \
    && rm -rf /var/lib/apt/lists/* \
    && rm -rf /usr/share/doc/* \
    && rm -rf /usr/share/man/* \
    && rm -rf /usr/share/locale/* \
    && rm -rf /usr/share/info/*

# 実行段階
FROM nvidia/cuda:11.8.0-base-ubuntu22.04 AS runtime

# 変数の定義（実行段階でも使用）
ARG UBUNTU_VERSION=22.04
ARG UBUNTU_NAME=jammy
ARG ARCH=amd64
ARG BUILD_MODE=release
ARG ENABLE_FASTER_WHISPER=0
ARG ENABLE_VCEENCC=0

# 環境変数の設定
ENV DEBIAN_FRONTEND=noninteractive
ENV TZ=Asia/Tokyo
ENV UBUNTU_VERSION=${UBUNTU_VERSION}
ENV UBUNTU_NAME=${UBUNTU_NAME}
ENV ARCH=${ARCH}
ENV BUILD_MODE=${BUILD_MODE}
ENV LANG=ja_JP.UTF-8
ENV LC_ALL=ja_JP.UTF-8
ENV LC_CTYPE=ja_JP.UTF-8

# NVIDIA Container Toolkit に渡す機能。
# NVEnc は video、CUDA/NVRTC は compute、nvidia-smi は utility、
# Vulkan / libplacebo 系は graphics が必要になる。
ENV NVIDIA_VISIBLE_DEVICES=all
ENV NVIDIA_DRIVER_CAPABILITIES=compute,utility,video,graphics
# NVIDIA Container Toolkit が /etc/vulkan/icd.d/nvidia_icd.json を注入する環境向け。
# Mesa/Intel/Radeon/lvp 側の ICD を誤って列挙して gpuinfo: device #1 エラーになるのを避ける。
ENV VK_ICD_FILENAMES=/etc/vulkan/icd.d/nvidia_icd.json

ENV QSVENCC_VER=8.17
ENV NVENCC_VER=9.20
ENV VCEENCC_VER=9.06
ENV AMDGPU_INSTALL_VER=25.35.1
ENV AMDGPU_INSTALL_DEB_VER=7.2.1.70201-1
ENV TSREPLACE_VER=0.19
ENV AVISYNTHCUDAFILTERS_VER=0.7.3
ENV AVISYNTH_VER=3.7.5
ENV FASTER_WHISPER_VER=r245.4
ENV LIBPLACEBO_VER=v7.360.1
ENV NVENC_SOURCE_REF=9.20
ENV NVENC_BUILD_JOBS=2
ENV RUSTUP_HOME=/usr/local/rustup
ENV CARGO_HOME=/usr/local/cargo
ENV PATH="/usr/local/cargo/bin:${PATH}"

# 実行に必要なパッケージのみインストール（デバッグモードの場合はビルドツールも含める）
# ENABLE_VCEENCC 時の AMF: repo.radeon.com amdgpu/6.4.4 pool は jammy(22.04): *_2202160.22.04_* と noble(24.04): *_2203192.24.04_* の二系統。ベース Ubuntu 22.04 のため前者を取得する。
RUN apt-get update && apt-get install -y \
    gpg \
    ca-certificates \
    curl \
    wget \
    tzdata \
    software-properties-common \
    p7zip-full \
    && add-apt-repository -y universe \
    && wget -qO - https://repositories.intel.com/gpu/intel-graphics.key | gpg --yes --dearmor --output /usr/share/keyrings/intel-graphics.gpg \
    && echo "deb [arch=amd64,i386 signed-by=/usr/share/keyrings/intel-graphics.gpg] https://repositories.intel.com/gpu/ubuntu ${UBUNTU_NAME} unified" \
      | tee /etc/apt/sources.list.d/intel-gpu-${UBUNTU_NAME}.list \
    && if [ "$ENABLE_VCEENCC" = "1" ]; then \
        wget https://repo.radeon.com/amdgpu-install/${AMDGPU_INSTALL_VER}/ubuntu/${UBUNTU_NAME}/amdgpu-install_${AMDGPU_INSTALL_DEB_VER}_all.deb -O amdgpu-install.deb \
        && apt-get install -y ./amdgpu-install.deb \
        && rm ./amdgpu-install.deb \
        && apt-get update \
        && amdgpu-install -y --usecase=opencl --opencl=rocr --no-dkms \
        && wget https://repo.radeon.com/amdgpu/6.4.4/ubuntu/pool/proprietary/a/amdgpu-pro-core/amdgpu-pro-core_25.10-2202160.22.04_all.deb \
        && wget https://repo.radeon.com/amdgpu/6.4.4/ubuntu/pool/proprietary/liba/libamdenc-amdgpu-pro/libamdenc-amdgpu-pro_25.10-2202160.22.04_amd64.deb \
        && wget https://repo.radeon.com/amdgpu/6.4.4/ubuntu/pool/proprietary/a/amf-amdgpu-pro/amf-amdgpu-pro_1.4.37-2202160.22.04_amd64.deb \
        && apt-get remove --purge -y amf-amdgpu-pro libamdenc-amdgpu-pro || true \
        && apt-get install -y --allow-downgrades \
            ./amdgpu-pro-core_25.10-2202160.22.04_all.deb \
            ./libamdenc-amdgpu-pro_25.10-2202160.22.04_amd64.deb \
            ./amf-amdgpu-pro_1.4.37-2202160.22.04_amd64.deb \
        && apt-mark hold amdgpu-pro-core libamdenc-amdgpu-pro amf-amdgpu-pro \
        && rm -f \
            ./amdgpu-pro-core_25.10-2202160.22.04_all.deb \
            ./libamdenc-amdgpu-pro_25.10-2202160.22.04_amd64.deb \
            ./amf-amdgpu-pro_1.4.37-2202160.22.04_amd64.deb \
        && if [ ! -e /lib/x86_64-linux-gnu/libOpenCL.so ] && [ -e /lib/x86_64-linux-gnu/libOpenCL.so.1 ]; then \
            ln -s /lib/x86_64-linux-gnu/libOpenCL.so.1 /lib/x86_64-linux-gnu/libOpenCL.so; \
        fi; \
    fi \
    && apt-get update \
    && apt-get install -y \
        gosu \
        git \
        python3 \
        python3-pip \
        xz-utils \
        locales \
        openssl \
        zlib1g \
        mkvtoolnix \
        opus-tools \
        build-essential \
        cmake \
        meson \
        ninja-build \
        pkg-config \
        autoconf \
        automake \
        libtool \
        libssl-dev \
        zlib1g-dev \
        python3-jinja2 \
        python3-mako \
        # Ubuntu 22.04では vulkan-headers は libvulkan-dev に統合されています。
        # shadercは環境差で欠落しやすいため使わず、libplaceboはglslang backendでビルドします。
        libvulkan1 \
        libvulkan-dev \
        vulkan-tools \
        glslang-dev \
        spirv-tools \
        spirv-headers \
        liblcms2-dev \
        libxxhash-dev \
        libunwind-dev \
        libass-dev \
        libfontconfig1-dev \
        libfreetype6-dev \
        libavutil-dev libavcodec-dev libavformat-dev libavfilter-dev libavdevice-dev libswresample-dev \
        intel-media-va-driver-non-free intel-opencl-icd libigfxcmrt7 libmfx1 libmfx-gen1.2 libva-drm2 libva-x11-2 ocl-icd-opencl-dev \
        cuda-nvrtc-11-8 cuda-nvrtc-dev-11-8 cuda-nvcc-11-8 cuda-cudart-dev-11-8 cuda-driver-dev-11-8 cuda-nvml-dev-11-8 libnpp-11-8 libnpp-dev-11-8 libcurand-dev-11-8 \
    && wget https://github.com/rigaya/QSVEnc/releases/download/${QSVENCC_VER}/qsvencc_${QSVENCC_VER}_${ARCH}.deb -O qsvencc.deb \
        && apt-get install -y ./qsvencc.deb \
        && rm ./qsvencc.deb \
    && wget https://github.com/rigaya/NVEnc/releases/download/${NVENCC_VER}/nvencc_${NVENCC_VER}_${ARCH}.deb -O nvencc.deb \
        && apt-get install -y ./nvencc.deb \
        && rm ./nvencc.deb \
    && if [ "$ENABLE_VCEENCC" = "1" ]; then \
        wget https://github.com/rigaya/VCEEnc/releases/download/${VCEENCC_VER}/vceencc_${VCEENCC_VER}_${ARCH}.deb -O vceencc.deb \
        && apt-get install -y ./vceencc.deb \
        && rm ./vceencc.deb; \
    fi \
    && wget https://github.com/rigaya/tsreplace/releases/download/${TSREPLACE_VER}/tsreplace_${TSREPLACE_VER}_${ARCH}.deb -O tsreplace.deb \
        && apt-get install -y ./tsreplace.deb \
        && rm ./tsreplace.deb \
    && if [ "$BUILD_MODE" = "debug" ]; then \
        apt-get install -y \
        software-properties-common \
        build-essential \
        nasm \
        cmake \
        meson \
        ninja-build \
        pkg-config \
        autoconf \
        automake \
        libtool \
        libssl-dev \
        libz-dev; \
    fi \
    && rm -rf /var/lib/apt/lists/* \
    && apt-get clean \
    && apt-get autoremove -y

# NVEncC の --vpp-colorspace は実行時に libnvrtc.so を dlopen する。
# cuda-nvrtc-dev-11-8 が通常は非バージョン付き symlink を提供するが、
# ベースイメージやapt状態によって欠ける場合に備えて補完する。
RUN set -eux; \
    CUDA_LIB="/usr/local/cuda/targets/x86_64-linux/lib"; \
    if [ -d "$CUDA_LIB" ]; then \
        if [ ! -e "$CUDA_LIB/libnvrtc.so" ] && [ -e "$CUDA_LIB/libnvrtc.so.11.2" ]; then \
            ln -s libnvrtc.so.11.2 "$CUDA_LIB/libnvrtc.so"; \
        fi; \
        if [ ! -e "$CUDA_LIB/libnvrtc-builtins.so" ] && [ -e "$CUDA_LIB/libnvrtc-builtins.so.11.8" ]; then \
            ln -s libnvrtc-builtins.so.11.8 "$CUDA_LIB/libnvrtc-builtins.so"; \
        fi; \
    fi; \
    ldconfig; \
    ldconfig -p | grep -E 'libvulkan|libnvrtc' || true

# タイムゾーンを確実にJSTへ固定
RUN ln -snf /usr/share/zoneinfo/$TZ /etc/localtime \
    && echo $TZ > /etc/timezone

# 日本語ロケールの設定
RUN locale-gen ja_JP.UTF-8 \
    && locale-gen en_US.UTF-8 \
    && update-locale LANG=ja_JP.UTF-8

# .NET SDK 10.0のインストール（デバッグモードの場合のみ）
RUN if [ "$BUILD_MODE" = "debug" ]; then \
        apt add-apt-repository ppa:dotnet/backports \
        && apt update \
        && apt install -y dotnet-sdk-10.0 \
        && rm -rf /var/lib/apt/lists/*; \
    fi

# AviSynth+/AvisynthCUDAFiltersのインストール（実行段階でも必要）
RUN wget https://github.com/rigaya/AviSynthCUDAFilters/releases/download/${AVISYNTHCUDAFILTERS_VER}/avisynth_${AVISYNTH_VER}-1_${ARCH}_Ubuntu${UBUNTU_VERSION}.deb -O avisynth.deb \
    && apt-get install -y ./avisynth.deb \
    && rm ./avisynth.deb \
    && wget https://github.com/rigaya/AviSynthCUDAFilters/releases/download/${AVISYNTHCUDAFILTERS_VER}/avisynthcudafilters_${AVISYNTHCUDAFILTERS_VER}-1_${ARCH}_Ubuntu${UBUNTU_VERSION}.deb -O avisynthcudafilters.deb \
    && apt-get install -y ./avisynthcudafilters.deb \
    && rm ./avisynthcudafilters.deb

RUN if [ "$ENABLE_FASTER_WHISPER" = "1" ]; then \
        wget https://github.com/Purfview/whisper-standalone-win/releases/download/Faster-Whisper-XXL/Faster-Whisper-XXL_${FASTER_WHISPER_VER}_linux.7z -O faster-whisper.7z \
        && mkdir -p /opt /app/exe_files \
        && 7z x faster-whisper.7z -o/opt/ \
        && chmod 755 /opt/ \
        && ln -s /opt/Faster-Whisper-XXL /app/exe_files/Faster-Whisper-XXL \
        && rm faster-whisper.7z; \
    fi

# ライブラリパスの設定
ENV LD_LIBRARY_PATH=/usr/local/lib:/usr/local/lib/x86_64-linux-gnu:/usr/local/cuda/lib64:/usr/local/cuda/targets/x86_64-linux/lib:/usr/lib/x86_64-linux-gnu:$LD_LIBRARY_PATH
ENV PKG_CONFIG_PATH=/usr/local/lib/pkgconfig:/usr/local/lib/x86_64-linux-gnu/pkgconfig:/usr/lib/x86_64-linux-gnu/pkgconfig:$PKG_CONFIG_PATH

# 作業ディレクトリの設定
WORKDIR /app

# ディレクトリ構造の作成
RUN mkdir -p /app/bat /app/config /app/exe_files/plugins64 /app/recorded /app/logo /app/output /app/profile /app/temp

# SCRename.py
RUN git clone --depth 1 -b 0.04 https://github.com/rigaya/SCRenamePy.git tmp_SCRenamePy \
    && mkdir -p exe_files/SCRenamePy \
    && mv tmp_SCRenamePy/SCRename.* exe_files/SCRenamePy/ \
    && rm -rf tmp_SCRenamePy

RUN wget https://github.com/rigaya/AutoBuildForAviUtlPlugins/releases/download/auto-build-20260620-071422/x264_3223_amd64_linux.tar.xz -O x264.tar.xz \
    && wget https://github.com/rigaya/AutoBuildForAviUtlPlugins/releases/download/auto-build-20260620-071422/x265_4.2%2B18_amd64_linux.tar.xz -O x265.tar.xz \
    && wget https://github.com/rigaya/AutoBuildForAviUtlPlugins/releases/download/auto-build-20260620-071422/SvtAv1EncApp_4.1.0-245_amd64_linux_clang.tar.xz -O svt-av1.tar.xz \
    && tar -xf x264.tar.xz -C /app/exe_files \
    && tar -xf x265.tar.xz -C /app/exe_files \
    && tar -xf svt-av1.tar.xz -C /app/exe_files \
    && rm x264.tar.xz x265.tar.xz svt-av1.tar.xz

# ビルド段階から必要なファイルをコピー
COPY --from=builder /usr/local/lib /usr/local/lib
COPY --from=builder /usr/local/bin /usr/local/bin
COPY --from=builder /usr/lib/x86_64-linux-gnu /usr/lib/x86_64-linux-gnu

# libplacebo を Vulkan 有効でビルドする。
# Ubuntu 22.04 向け NVEncC 配布バイナリでは libplacebo が内蔵/静的扱いで、

# Ubuntu 22.04 の apt 版 meson は 0.61.2 で、libplacebo v7.360.1 の要求 >=0.63 を満たしません。
# /usr/local/bin が /usr/bin より優先されるため、pip版mesonを使います。
RUN python3 -m pip install --no-cache-dir --upgrade "meson>=1.3,<2" "ninja"

# 実行時に「libplacebo compiled without Vulkan support!」になることがあるため、
# libplacebo と NVEncC を同じイメージ内で再ビルドして /usr/bin/nvencc を置き換える。
# 注意: NVEncC実行時ログの「libplacebo v7.362.0」はGitタグ名ではないため、実在する最新リリース v7.360.1 を使う。
RUN set -eux;     which meson; meson --version;     git clone --depth=1 --branch "${LIBPLACEBO_VER}" --recursive https://github.com/haasn/libplacebo.git /tmp/libplacebo;     meson setup /tmp/libplacebo/build /tmp/libplacebo         --prefix=/usr/local         --buildtype=release         -Ddefault_library=shared         -Dvulkan=enabled         -Dshaderc=disabled         -Dglslang=enabled         -Dlcms=enabled         -Ddemos=false         -Dtests=false;     meson compile -C /tmp/libplacebo/build -j"$(nproc)";     meson install -C /tmp/libplacebo/build;     rm -rf /tmp/libplacebo;     ldconfig;     pkg-config --modversion libplacebo;     ldconfig -p | grep -E 'libplacebo|libvulkan'

# NVEnc 9.20 の Meson option では enable_libplacebo / enable_vulkan / enable_vmaf は
# booleanではなく combo(auto/enabled/disabled) なので、enabled/disabledを指定する。


# libdovi が Cargo edition2024 を要求するため、Ubuntu 22.04 apt版cargoでは古すぎます。
# rustupのstable toolchainを /usr/local/cargo に入れ、Meson/NVEncからもこちらを使わせます。
RUN set -eux; \
    curl --proto '=https' --tlsv1.2 -sSf https://sh.rustup.rs \
      | sh -s -- -y --profile minimal --default-toolchain stable; \
    rustc --version; \
    cargo --version

# cargo-c の依存 openssl-sys が openssl/opensslv.h を要求するため、libssl-dev を runtime のメインapt一覧に入れる。
# zlib1g-dev も Rust/Cargo の libgit2/curl 系native依存で使われやすいため追加。
# cargo-c実行前に /usr/include/openssl/opensslv.h の存在確認も行う。
# cargo installの出力先 /usr/local/cargo/bin をPATHに入れ、/usr/local/binにもsymlinkする。
# rustup stable なら cargo-c 0.10系と libdovi の edition2024 の両方に対応できる。
# NVEnc の meson setup 前に cargo-c を固定インストールする。
RUN set -eux; \
    command -v rustc; rustc --version; \
    command -v cargo; cargo --version; \
    dpkg -L libssl-dev | grep -F '/openssl/opensslv.h'; \
    test -f /usr/include/openssl/opensslv.h; \
    cargo install cargo-c --version "0.10.23+cargo-0.97.1" --locked; \
    /usr/local/cargo/bin/cargo-cbuild --version; \
    /usr/local/cargo/bin/cargo-cinstall --version; \
    ln -sf /usr/local/cargo/bin/cargo-capi /usr/local/bin/cargo-capi; \
    ln -sf /usr/local/cargo/bin/cargo-cbuild /usr/local/bin/cargo-cbuild; \
    ln -sf /usr/local/cargo/bin/cargo-cinstall /usr/local/bin/cargo-cinstall; \
    ln -sf /usr/local/cargo/bin/cargo-ctest /usr/local/bin/cargo-ctest; \
    command -v cargo-cbuild; \
    command -v cargo-cinstall

# dovi は NVEnc 9.20 の meson option では無効化できないため、system dovi が無い場合は bundled libdovi のビルドに cargo が必要。
# libvship は画質指標系でAmatsukazeの通常エンコードには不要なので disabled に固定する。

# NVEncCore/rgy_perf_monitor.h が nvml.h をincludeするため、NVML開発ヘッダを確認する。
# cuda-nvml-dev-11-8 で通常は /usr/local/cuda/targets/x86_64-linux/include/nvml.h が入る。
RUN set -eux; \
    find /usr/local/cuda /usr -name nvml.h -print; \
    if [ ! -e /usr/local/cuda/targets/x86_64-linux/include/nvml.h ]; then \
        found="$(find /usr/local/cuda /usr -name nvml.h -print -quit)"; \
        test -n "$found"; \
        mkdir -p /usr/local/cuda/targets/x86_64-linux/include; \
        ln -sf "$found" /usr/local/cuda/targets/x86_64-linux/include/nvml.h; \
    fi; \
    test -f /usr/local/cuda/targets/x86_64-linux/include/nvml.h

# NVEncCore/NVEncFilterDeband.cu が curand_kernel.h をincludeするため、
# libcurand-dev-11-8 でcuRAND開発ヘッダを入れておく。
RUN set -eux; \
    find /usr/local/cuda /usr -name curand_kernel.h -print; \
    test -f /usr/local/cuda/targets/x86_64-linux/include/curand_kernel.h


# Ubuntu 22.04 の FFmpeg 4.4/libavutil 56 では AVChannelLayout 構造体ではなく uint64_t channel_layout 経路になる。
# NVEnc 9.20 の rgy_output_avcodec.cpp にある
#   uniuqeRGYChannelLayout enc_channel_layout_standard(nullptr, nullptr);
# は std::unique_ptr<uint64_t> に対して2引数コンストラクタを呼んでしまうためビルド不能。
# default constructに置換すると old/new FFmpeg の両方で通る。


# NVEncCのCUDA/C++ビルドはメモリ消費が大きく、-j$(nproc) だとDocker内でサブプロセスが落ちても
# ログに明確なFAILED行が残らず ninja: build stopped だけになることがある。
# まずは -j2 に制限し、失敗時に原因が見えるよう -v で詳細コマンドを出す。

# NVEncC を Vulkan/libplacebo 有効で再ビルドして、配布 .deb 由来の /usr/bin/nvencc を置き換える。
# -Denable_vapoursynth=false は Amatsukaze 連携では主に y4m/avs 入力を使うため最小化。
# NVEnc 9.20 には enable_dtl option がないため指定しない。
RUN set -eux;     test -f /usr/local/cuda/targets/x86_64-linux/include/nvml.h;     command -v cargo; cargo --version; command -v cargo-cbuild; cargo-cbuild --version;     git clone --depth=1 --branch "${NVENC_SOURCE_REF}" --recursive https://github.com/rigaya/NVEnc.git /tmp/NVEnc;     cd /tmp/NVEnc;     sed -i 's/uniuqeRGYChannelLayout enc_channel_layout_standard(nullptr, nullptr);/uniuqeRGYChannelLayout enc_channel_layout_standard;/' NVEncCore/rgy_output_avcodec.cpp; \
    grep -n 'enc_channel_layout_standard' NVEncCore/rgy_output_avcodec.cpp; \
    meson setup build         --prefix=/usr/local         --buildtype=release         -Denable_libplacebo=enabled         -Denable_vulkan=enabled         -Dlibplacebo_static=false         -Denable_avisynth=true         -Denable_vapoursynth=false         -Denable_libass=true         -Denable_vmaf=disabled         -Denable_libvship=disabled;     meson compile -C build -j"${NVENC_BUILD_JOBS:-2}" -v;     meson install -C build || true;     if [ -x /tmp/NVEnc/build/nvencc ]; then install -m 755 /tmp/NVEnc/build/nvencc /usr/local/bin/nvencc; fi;     test -x /usr/local/bin/nvencc;     rm -rf /tmp/NVEnc;     ln -sf /usr/local/bin/nvencc /usr/bin/nvencc;     ldconfig;     /usr/bin/nvencc --check-environment || true

# Amatsukazeのインストール
RUN curl -s https://api.github.com/repos/rigaya/Amatsukaze/releases/latest \
        | grep "browser_download_url.*tar.xz" | grep "Ubuntu${UBUNTU_VERSION}" | cut -d : -f 2,3 | tr -d \" \
        | wget -i - -O - | tar -xJ -C /app \
        && if [ -f /app/scripts/install.sh ]; then /app/scripts/install.sh; fi

# for debug
#COPY Amatsukaze_Ubuntu22.04_r926.tar.xz /app
#RUN tar -xJf /app/Amatsukaze_Ubuntu22.04_r926.tar.xz -C /app \
#    && if [ -f /app/scripts/install.sh ]; then /app/scripts/install.sh; fi \
#    && rm /app/Amatsukaze_Ubuntu22.04_r926.tar.xz

# デバッグ用のシェルスクリプトを作成（デバッグモードの場合のみ）
RUN if [ "$BUILD_MODE" = "debug" ]; then \
        echo '#!/bin/bash' > /app/debug-build.sh && \
        echo 'cd /app/Amatsukaze-src' >> /app/debug-build.sh && \
        echo './scripts/build.sh /app build --debug' >> /app/debug-build.sh && \
        echo 'if [ -f /app/scripts/install.sh ]; then /app/scripts/install.sh; fi' >> /app/debug-build.sh && \
        chmod +x /app/debug-build.sh; \
    fi

# エントリーポイントスクリプトを作成
RUN cat <<'EOF' > /app/entrypoint.sh
#!/bin/bash
set -e
umask 022

DEFAULT_UID=${RUN_UID:-1000}; DEFAULT_GID=${RUN_GID:-1000};
if ! getent group "$DEFAULT_GID" >/dev/null 2>&1; then groupadd -g "$DEFAULT_GID" appgroup; fi

RENDER_GROUP=""
if [ -d /dev/dri ]; then
  ls -l /dev/dri/ || true
  if [ -c /dev/dri/renderD128 ]; then
    RENDER_GID=$(stat -c "%g" /dev/dri/renderD128 2>/dev/null || echo "")
    echo "RENDER_GID: $RENDER_GID"
    if [ -n "$RENDER_GID" ] && [ "$RENDER_GID" != "" ]; then
      RENDER_GROUP=$(getent group "$RENDER_GID" | cut -d: -f1 || true)
      if [ -z "$RENDER_GROUP" ]; then
        if getent group render >/dev/null 2>&1; then
          groupmod -o -g "$RENDER_GID" render
          RENDER_GROUP=render
        else
          groupadd -g "$RENDER_GID" render
          RENDER_GROUP=render
        fi
      fi
    fi
  fi
fi

if ! getent passwd "$DEFAULT_UID" >/dev/null 2>&1; then useradd -u "$DEFAULT_UID" -g "$DEFAULT_GID" -m -s /bin/bash appuser; fi
chown -R --no-dereference "$DEFAULT_UID:$DEFAULT_GID" /app
if [ -d /opt/Faster-Whisper-XXL ]; then
  find /opt/Faster-Whisper-XXL -type d -exec chown "$DEFAULT_UID:$DEFAULT_GID" {} +
  chmod ugo+rx /opt/Faster-Whisper-XXL/faster-whisper-xxl
fi
GROUPS_TO_ADD=()
if getent group video >/dev/null 2>&1; then GROUPS_TO_ADD+=("video"); fi
if [ -n "$RENDER_GROUP" ]; then GROUPS_TO_ADD+=("$RENDER_GROUP"); elif getent group render >/dev/null 2>&1; then GROUPS_TO_ADD+=("render"); fi
if [ ${#GROUPS_TO_ADD[@]} -gt 0 ]; then
  usermod -aG "$(IFS=,; echo "${GROUPS_TO_ADD[*]}")" "$(id -nu "${DEFAULT_UID}")"
fi
exec gosu "$DEFAULT_UID" "$@"
EOF
RUN sed -i 's/\r$//' /app/entrypoint.sh \
    && chmod +x /app/entrypoint.sh

# デフォルトコマンド（モードに応じて切り替え）
ENTRYPOINT ["./entrypoint.sh"]
CMD if [ "$BUILD_MODE" = "debug" ]; then /bin/bash; else ./AmatsukazeServer.sh; fi
